<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FoodZone</title>

<!-- Bootstrap CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
body {
  background: #f8f9fa;
  font-family: Arial;
}

/* Navbar */
.navbar {
  background: linear-gradient(45deg,#ff5722,#ff9800);
}
.navbar-brand {
  color: white !important;
  font-weight: bold;
}

/* Welcome Section with Background */
.welcome {
  background: url('https://images.unsplash.com/photo-1504674900247-0877df9cc836') center/cover no-repeat;
  color: white;
  padding: 80px;
  text-align: center;
  border-radius: 15px;
  margin-top: 20px;
  position: relative;
}
.welcome::after {
  content: "";
  position: absolute;
  top:0; left:0;
  width:100%; height:100%;
  background: rgba(0,0,0,0.5);
  border-radius: 15px;
}
.welcome h2, .welcome p {
  position: relative;
  z-index: 2;
}

/* Cards */
.card {
  border-radius: 15px;
  overflow: hidden;
  transition: 0.3s;
}
.card:hover {
  transform: scale(1.05);
}
.card img {
  height: 180px;
  object-fit: cover;
}

/* Cart */
.cart-box {
  background: white;
  padding: 20px;
  border-radius: 15px;
  margin-top: 30px;
  box-shadow: 0 4px 10px rgba(0,0,0,0.1);
}

.price {
  color: green;
  font-weight: bold;
}
</style>
</head>

<body>

<!-- Navbar -->
<nav class="navbar navbar-expand-lg">
  <div class="container">
    <a class="navbar-brand">🍔 FoodZone</a>
    <span class="text-white">🛒 (<span id="count">0</span>)</span>
  </div>
</nav>

<div class="container">

  <!-- Welcome -->
  <div class="welcome">
    <h2>Welcome to FoodZone 🍔</h2>
    <p>Delicious food delivered to your doorstep</p>
  </div>

  <!-- Food Items -->
  <div class="row mt-4" id="foodList"></div>

  <!-- Cart BELOW Items -->
  <div class="cart-box">
    <h4>🛒 Your Cart</h4>
    <ul id="cartItems" class="list-group mb-3"></ul>
    <h5>Total: $<span id="total">0</span></h5>
    <button class="btn btn-success w-100" onclick="payNow()">Pay Now</button>
  </div>

</div>

<!-- Success Modal -->
<div class="modal fade" id="successModal">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content text-center p-4">
      <h3>✅ Order Confirmed</h3>
      <p>Your order is on the way 🚀</p>
      <button class="btn btn-success" data-bs-dismiss="modal">OK</button>
    </div>
  </div>
</div>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<script>

// Food Data
const foods = [
  {name:"Burger", price:115, img:"https://images.unsplash.com/photo-1568901346375-23c9450c58cd"},
  {name:"Pizza", price:228, img:"https://images.unsplash.com/photo-1600891964599-f61ba0e24092"},
  {name:"Pasta", price:187, img:"https://images.unsplash.com/photo-1546069901-ba9599a7e63c"},
  {name:"Fries", price:233, img:"https://images.unsplash.com/photo-1550547660-d9450f859349"},
  {name:"Sandwich", price:114, img:"https://images.unsplash.com/photo-1551024709-8f23befc6f87"}
];

let cart = [];

// Load Foods
function loadFoods() {
  let list = document.getElementById("foodList");

  foods.forEach((food, index) => {
    list.innerHTML += `
      <div class="col-md-4 mb-4">
        <div class="card">
          <img src="${food.img}">
          <div class="card-body text-center">
            <h5>${food.name}</h5>
            <p class="price">$${food.price}</p>
            <button class="btn btn-primary" onclick="addToCart(${index})">Add</button>
          </div>
        </div>
      </div>
    `;
  });
}

// Add to Cart
function addToCart(index) {
  cart.push(foods[index]);
  updateCart();
}

// Remove
function removeItem(index) {
  cart.splice(index, 1);
  updateCart();
}

// Update Cart
function updateCart() {
  let cartItems = document.getElementById("cartItems");
  let total = 0;

  cartItems.innerHTML = "";

  cart.forEach((item, index) => {
    total += item.price;

    cartItems.innerHTML += `
      <li class="list-group-item d-flex justify-content-between">
        ${item.name} - $${item.price}
        <button class="btn btn-danger btn-sm" onclick="removeItem(${index})">X</button>
      </li>
    `;
  });

  document.getElementById("total").innerText = total;
  document.getElementById("count").innerText = cart.length;
}

// Payment
function payNow() {
  if(cart.length === 0){
    alert("Cart is empty!");
    return;
  }

  let modal = new bootstrap.Modal(document.getElementById("successModal"));
  modal.show();

  cart = [];
  updateCart();
}

// Init
loadFoods();

</script>

</body>
</html>
